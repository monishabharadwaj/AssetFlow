DATABASE_URL=postgresql://postgres:Root%40123@localhost:5432/assetflow_ai
APP_NAME=AssetFlow AI
DEBUG=true

# ML (paths default to ml/artifacts/ if unset)
ML_ENABLED=true

# Ollama assistant (formats DB-backed answers; set false to use templates only)
ASSISTANT_USE_OLLAMA=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_SECONDS=30

# Auth (JWT)
AUTH_ENABLED=true
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_EXPIRE_MINUTES=480

# Seeded accounts use unique temporary passwords (printed during seed) with must_change_password=true

# Background AI pipeline scheduler (optional — off by default for local dev)
SCHEDULER_ENABLED=false
SCHEDULER_INTERVAL_MINUTES=60
SCHEDULER_RUN_ON_STARTUP=false
POLICY_AUTOMATION_ENABLED=true
