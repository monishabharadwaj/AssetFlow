# AssetFlow AI — production env template (Option A EC2)
# Copy to /home/ubuntu/AssetFlow-AI/.env and replace CHANGE_ME / YOUR_EC2_PUBLIC_IP.
# Do NOT commit real secrets.

DATABASE_URL=postgresql://assetflow:CHANGE_ME@localhost:5432/assetflow_ai
APP_NAME=AssetFlow AI
DEBUG=false

# ML (absolute paths on the EC2 host)
ML_ENABLED=true
ML_MODEL_PATH=/home/ubuntu/AssetFlow-AI/ml/artifacts/model.pt
ML_FEATURE_STATS_PATH=/home/ubuntu/AssetFlow-AI/ml/artifacts/feature_stats.json

# Skip Ollama on first deploy (assistant uses template fallbacks)
ASSISTANT_ENABLED=true
ASSISTANT_USE_OLLAMA=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_SECONDS=30

# Auth — generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_ENABLED=true
JWT_SECRET_KEY=CHANGE_ME
JWT_EXPIRE_MINUTES=480

# CORS — optional when UI uses same-origin VITE_API_BASE_URL=/api/v1
# Needed for Swagger UI from another origin or a custom domain
CORS_ORIGINS=http://YOUR_EC2_PUBLIC_IP

SCHEDULER_ENABLED=false
SCHEDULER_INTERVAL_MINUTES=60
SCHEDULER_RUN_ON_STARTUP=false
POLICY_AUTOMATION_ENABLED=true
