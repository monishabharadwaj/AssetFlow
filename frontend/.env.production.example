# Same-origin API via nginx on production EC2 (recommended).
# Copy to .env.production before: npm run build
#
# Windows: save as UTF-8 (not UTF-16). PowerShell example:
#   [IO.File]::WriteAllText(".env.production", "VITE_API_BASE_URL=/api/v1`n", (New-Object Text.UTF8Encoding $false))
VITE_API_BASE_URL=/api/v1
